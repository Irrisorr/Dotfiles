{
    "allowDuplicates": false,
    "historyFile": "clipboard_history.json",
    "maxHistory": 100,
    "deleteAfter": 14400,
    "logFile": "clipse.log",
    "themeFile": "custom_theme.json",
    "tempDir": "tmp_files",
    "enableDescription": false,
    "keyBindings": {
        "choose": "space",
        "up": "up,k,л",
        "down": "down,j,о",
        "nextPage": "right,l,д",
        "prevPage": "left,h,р",
        "quit": "q,esc,й",
        "preview": "enter",
        "end": "end",
        "filter": "/",
        "home": "home",
        "more": "?",
        "remove": "x",
        "selectDown": "ctrl+down",
        "selectSingle": "s",
        "clearSelected": "S",
        "selectUp": "ctrl+up",
        "togglePin": "p",
        "togglePinned": "tab",
        "yankFilter": "ctrl+s"
    },
    "imageDisplay": {
        "type": "kitty",
        "scaleX": 20,
        "scaleY": 20,
        "heightCut": 2
    }
}